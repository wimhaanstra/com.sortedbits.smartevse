          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=smartevse"
          },
          {
            "name": "amps",
            "type": "number",
            "min": 0,
            "max": 80,
            "step": 1
          }
        ]
      },
      {
        "id": "set_enable_c2",
