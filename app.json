            "values": [
              {
                "id": "Not present",
                "label": {
                  "en": "Not present",
                  "nl": "Niet aanwezig"
                }
              },
              {
                "id": "Always Off",
                "label": {
                  "en": "Always off",
                  "nl": "Altijd uit"
                }
              },
              {
                "id": "Solar Off",
                "label": {
                  "en": "Off on solar",
                  "nl": "Uit bij zon"
                }
              },
              {
                "id": "Always On",
                "label": {
                  "en": "Always on",
                  "nl": "Altijd aan"
                }
              },
              {
                "id": "Auto",
                "label": {
                  "en": "Auto",
                  "nl": "Automatisch"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "set_led_color",
