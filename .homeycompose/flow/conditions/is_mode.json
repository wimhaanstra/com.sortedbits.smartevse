        { "id": "Normal", "label": { "en": "Normal", "nl": "Normaal" } },
        { "id": "Smart", "label": { "en": "Smart", "nl": "Slim" } },
        { "id": "Solar", "label": { "en": "Solar", "nl": "Zon" } },
        { "id": "Pause", "label": { "en": "Pause", "nl": "Pauze" } }
      ]
    }
  ]
}
