                  "en": "Off",
                  "nl": "Uit"
                }
              },
              {
                "id": "Normal",
                "label": {
                  "en": "Normal",
                  "nl": "Normaal"
                }
              },
              {
                "id": "Smart",
                "label": {
                  "en": "Smart",
                  "nl": "Slim"
                }
              },
              {
                "id": "Solar",
